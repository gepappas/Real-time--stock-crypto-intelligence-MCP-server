# Copy to .env for local development
MCP_TRANSPORT=stdio           # "stdio" for Claude Desktop, "http" for production
PORT=8080
HOST=0.0.0.0
WEB_CONCURRENCY=1

# Public URL of your deployment (used for SEO sitemap & Open Graph)
SITE_URL=https://revolut-pulse.lovable.app

# Redis (optional – stampede-safe caching, defaults to in-memory)
REDIS_URL=redis://localhost:6379

# Database (optional – SaaS billing/usage, defaults to SQLite)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/revolut_pulse

# Revolut Open Banking (optional)
REVOLUT_ENV=sandbox
REVOLUT_CLIENT_ID=
REVOLUT_CERT_PATH=./certs/transport.pem
REVOLUT_KEY_PATH=./certs/private.key

# Revolut X Crypto (optional)
REVOLUT_X_API_KEY=
REVOLUT_X_PRIVATE_KEY=

# Unofficial Pocket / Vault API (optional)
REVOLUT_DEVICE_ID=
REVOLUT_PHONE_TOKEN=

# Webhook for alerts (optional)
MCPRICE_ALERT_WEBHOOK=
